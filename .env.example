# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env
#
# Convention :
#   - .env contient les secrets et les valeurs spécifiques au déploiement
#   - configs/baseline.yaml contient les modèles et hyperparamètres algorithmiques

# ── Pinecone (secrets + déploiement) ─────────────────────
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=rag-test2
PINECONE_NAMESPACE=__default__

# ── HuggingFace (secret) ─────────────────────────────────
HF_TOKEN=hf_your_token_here
